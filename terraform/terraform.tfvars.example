# Copy this file to terraform.tfvars and fill in required values.
# terraform.tfvars is gitignored and should never be committed.

aws_region  = "us-east-1"
environment = "staging"

# Container image tag pushed by CI
# container_image_tag    = "latest"
# container_architecture = "ARM64"   # ARM64 (Graviton, default) or X86_64

# Notifications (optional, shared by both stacks)
# ses_from_address = "noreply@example.com"
# fcm_project_id   = "my-firebase-project"

# ECR cross-region replication (image-only DR)
# dr_enabled = true
# dr_region  = "us-west-2"

# =============================================================================
# Testnet stack (Stellar testnet)
# =============================================================================
# testnet_enabled              = true
# testnet_jwt_secret           = "CHANGE_ME_testnet_jwt_secret"
# testnet_soroban_contract_id  = "CABC123..."
# testnet_server_desired_count = 1
# testnet_worker_desired_count = 1
# testnet_rds_instance_class   = "db.t3.micro"
# testnet_redis_node_type      = "cache.t3.micro"
# testnet_certificate_arn      = ""
# testnet_vpc_cidr             = "10.2.0.0/16"

# =============================================================================
# Live stack (Stellar pubnet / mainnet)
# =============================================================================
# live_enabled              = true
# live_jwt_secret           = "CHANGE_ME_live_jwt_secret"
# live_server_desired_count = 2
# live_worker_desired_count = 2
# live_rds_instance_class   = "db.t3.small"
# live_redis_node_type      = "cache.t3.small"
# live_certificate_arn      = "arn:aws:acm:us-east-1:123456789:certificate/abc-123"
# live_vpc_cidr             = "10.3.0.0/16"
